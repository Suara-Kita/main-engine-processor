# ─────────────────────────────────────────────
# PostgreSQL (point to host when running locally)
# ─────────────────────────────────────────────
DATABASE_URL=postgres://voter_app:changeme@localhost:5433/voter_intelligence

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis

# ─────────────────────────────────────────────
# Neo4j
# ─────────────────────────────────────────────
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─────────────────────────────────────────────
# LLM (OpenRouter)
# ─────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-120b
LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=

# ─────────────────────────────────────────────
# LLM Fallback (for Mandarin/Tamil)
# ─────────────────────────────────────────────
FALLBACK_LLM_ENDPOINT=
FALLBACK_LLM_MODEL=qwen/qwen3.5-397b-a17b
FALLBACK_LLM_API_KEY=

# ─────────────────────────────────────────────
# Main Triage Engine
# ─────────────────────────────────────────────
WORKER_COUNT=4

# ─────────────────────────────────────────────
# Queues
# ─────────────────────────────────────────────
QUEUE_VOTER_INPUTS=queue:voter_inputs
QUEUE_APPROVED_ACTIONS=queue:approved_actions

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
RUST_LOG=info
